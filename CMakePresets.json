{
  "version": 3,
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (RelWithDebInfo)",
      "binaryDir": "${sourceDir}/build/default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": { "type": "STRING", "value": "RelWithDebInfo" },
        "CMAKE_CXX_STANDARD": { "type": "STRING", "value": "23" },
        "CMAKE_C_COMPILER": { "type": "FILEPATH", "value": "$env{CC}" },
        "CMAKE_CXX_COMPILER": { "type": "FILEPATH", "value": "$env{CXX}" },
        "_comment_prefix": "dev installs (arrow-hdf, phlex-arrow-common) + the Spack view.",
        "CMAKE_PREFIX_PATH": { "type": "PATH", "value": "/devel/ddm/install;/devel/ddm/local" }
      }
    }
  ],
  "buildPresets": [ { "name": "default", "configurePreset": "default" } ],
  "testPresets": [ { "name": "default", "configurePreset": "default", "output": { "outputOnFailure": true } } ]
}
